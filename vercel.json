{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist/logicfit-app/browser",
  "installCommand": "npm install",
  "framework": "angular",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://logicfit.runasp.net/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
